---
import ProyectTag from "./ProyectTag.astro";
import ASCSharp from "../../assets/Proyects/ASCSharp.png";
import BucketNetwork from "../../assets/Proyects/BucketNetwork.png";
import PasswordGenerator from "../../assets/Proyects/PasswordGenerator.png";
---
<div class="flex flex-col">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold bg-clip-text text-white">
        Mis proyectos
      </h2>
    </div>
    <div class="relative w-full max-w-5xl mx-auto overflow-hidden">

  <div id="carousel" class="flex transition-transform duration-500 ease-in-out">

    <div class="w-full shrink-0 px-4">
      <ProyectTag 
        Title="Bucket network" 
        Description="BucketNetwork is a social platform designed for university purposes, aimed at facilitating the creation and interaction with user-generated content."
        Status="I think it's done" 
        ImgSrc={BucketNetwork}
      >
        <a target="_blank" href="https://github.com/JhersonCastro/PostHiveDemo" class="text-blue-400 hover:text-blue-600">
          Clic to see the project
        </a>
      </ProyectTag>
    </div>

    <div class="w-full shrink-0 px-4">
      <ProyectTag 
        Title="Password Generator" 
        Description="A lightweight tool designed to generate secure passwords with customizable options such as length, symbols, numbers, and uppercase letters."
        Status="Completed" 
        ImgSrc={PasswordGenerator}
      >
        <a target="_blank" href="https://github.com/JhersonCastro/passwordGenerator" class="text-blue-400 hover:text-blue-600">
          Clic to see the project
        </a>
      </ProyectTag>
    </div>

    <div class="w-full shrink-0 px-4">
      <ProyectTag 
        Title="Ascsharp" 
        Description="Ascsharp is a simple and fast notepad-style text editor built with WPF and C#."
        Status="Completed" 
        ImgSrc={ASCSharp}
      >
        <a target="_blank" href="https://github.com/JhersonCastro/ASCSharp" class="text-blue-400 hover:text-blue-600">
          Clic to see the project
        </a>
      </ProyectTag>
    </div>

  </div>

  <button id="prev"
    class="absolute left-5 top-1/2 -translate-y-1/2 bg-black/40 text-white px-3 py-2 rounded">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
    </svg>
  </button>

  <button id="next"
    class="absolute right-5 top-1/2 -translate-y-1/2 bg-black/40 text-white px-3 py-2 rounded transition-transform duration-200 hover:scale-110">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </button>

</div>
</div>
<script>
  const carousel = document.getElementById("carousel");
  const slides = carousel!.children;
  const total = slides.length;

  let index = 0;

  function updateCarousel() {
    carousel!.style.transform = `translateX(-${index * 100}%)`;
  }

  document.getElementById("next")!.onclick = () => {
    index = (index + 1) % total;
    updateCarousel();
  };

  document.getElementById("prev")!.onclick = () => {
    index = (index - 1 + total) % total;
    updateCarousel();
  };
  

</script>
