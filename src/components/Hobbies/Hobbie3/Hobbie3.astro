---
import BileTitanDeath from "./BileTitanDeath.astro";
---

<section id="videojuegos-section" class="relative min-h-screen py-16 md:py-24 bg-linear-to-br from-purple-900 via-purple-700 to-purple-900 text-white overflow-hidden">
  
  <div class="absolute inset-0 overflow-hidden opacity-10 pointer-events-none">
    <div class="absolute top-10 left-[10%] w-2 h-2 bg-green-400 animate-ping"></div>
    <div class="absolute top-20 left-[30%] w-3 h-3 bg-blue-400 animate-pulse"></div>
    <div class="absolute top-40 left-[70%] w-2 h-2 bg-yellow-400 animate-bounce"></div>
    <div class="absolute bottom-20 left-[50%] w-4 h-4 bg-red-400 animate-ping"></div>
    <div class="absolute bottom-40 left-[20%] w-2 h-2 bg-purple-400 animate-pulse"></div>
  </div>

  <div class="container mx-auto px-4 max-w-7xl relative z-20">
    
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-blue-400">
        Videojuegos
      </h2>
    </div>

    <!-- Bloque principal -->
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16 min-h-[60vh]">
      
      <!-- Columna izquierda: Texto -->
      <div class="flex-1 text-center lg:text-left space-y-6 order-2 lg:order-1">
        
        <p class="text-xl md:text-2xl lg:text-3xl leading-relaxed text-purple-50">
          Los videojuegos son mi escape favorito. Desde 
          <span class="font-semibold text-transparent bg-clip-text bg-gradient-to-r from-green-300 to-blue-300">
            Helldivers 2
          </span> 
          hasta clásicos como 
          <span class="font-semibold text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 to-orange-300">
            Minecraft
          </span>, 
          cada partida es una nueva aventura. Me encanta la estrategia, el trabajo en equipo y la emoción de superar desafíos.
        </p>


        <!-- Badge de Helldivers -->
        <div class="inline-flex items-center gap-2 bg-green-900/30 backdrop-blur-sm px-4 py-2 rounded-full border border-green-500/30 mt-4">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          <span class="text-sm">Jugando ahora: Helldivers 2</span>
        </div>
      </div>

      <!-- Columna derecha: Componente BileTitanDeath -->
      <div class="flex-1 w-full order-1 lg:order-2">
        <div class="relative">
          <div class="absolute -inset-1 bg-gradient-to-r from-green-500 to-blue-500 rounded-3xl blur-xl opacity-50"></div>
          
          <div class="relative bg-purple-900/30 backdrop-blur-sm rounded-2xl border-2 border-white/20 overflow-hidden shadow-2xl">
            <BileTitanDeath />
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style is:global>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(10deg); }
  }
  
  .pixel-float {
    animation: float 6s ease-in-out infinite;
  }
  
  #videojuegos-section {
    min-height: 100vh;
    height: auto;
  }
</style>