---
---

<section id="biletitan-section">
  <canvas id="animationCanvas" width="1280" height="720"></canvas>
</section>

<style>
#biletitan-section {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
  min-height: 500px;
}

#animationCanvas {
  width: 100%;
  height: auto;
  max-height: 70vh;
  background: #000;
  border-radius: 12px;
}
</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

document.addEventListener('DOMContentLoaded', () => {
  const canvas = document.getElementById("animationCanvas");
  if (!canvas) {
    console.error("Canvas no encontrado");
    return;
  }
  
  const context = canvas.getContext("2d");

  const frameCount = 36;
  const currentFrame = (index: string) => `/Astro-Web/Helldivers/frame_${String(index).padStart(4, '0')}.jpg`;

  const images : HTMLImageElement[]= [];
  let imagesLoaded = 0;

  for (let i = 1; i <= frameCount; i++) {
    const img = new Image();
    img.src = currentFrame(i);
    
    images.push(img);
  }

  images[0].onload = () => {
    render(0);
  };
  function render(index) {
    const img = images[index];
    if (img && img.complete && img.naturalWidth > 0) {
      context.clearRect(0, 0, canvas.width, canvas.height);
      
      const scale = Math.min(
        canvas.width / img.naturalWidth,
        canvas.height / img.naturalHeight
      );
      
      const x = (canvas.width - img.naturalWidth * scale) / 2;
      const y = (canvas.height - img.naturalHeight * scale) / 2;
      
      context.drawImage(
        img, 
        0, 0, img.naturalWidth, img.naturalHeight,
        x, y, img.naturalWidth * scale, img.naturalHeight * scale
      );
    }
  }

  const st = ScrollTrigger.create({
    trigger: "#biletitan-section",
    start: "top 70%",
    end: "bottom 40%",
    scrub: .5,
    id: "biletitan-animation",
    onUpdate: (self) => {
      const frameIndex = Math.floor(self.progress * (frameCount - 1));
      render(frameIndex);
    },
  });

  return () => {
    if (st) st.kill();
  };
});
</script>