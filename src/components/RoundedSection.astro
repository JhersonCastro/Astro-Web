---
export interface Props {
  imagenSrc?: string;
  textos?: string[];
}
import { Image } from "astro:assets";

import FrameMiku  from "../assets/FrameMiku.png";
const { 
  imagenSrc = FrameMiku,
  textos = ["Nivel: Universidad", "Institución: Universidad del cauca", "Años: 2023-2026"]
} = Astro.props;
---
<section id="RotationSection" class="relative min-h-screen overflow-x-hidden flex flex-col lg:flex-row">
  <div class="hidden lg:flex w-1/2 justify-start relative overflow-hidden">
    <div class="w-162.5 aspect-square absolute left-0 top-1/2 -translate-y-1/2 -translate-x-[55%]" id="dona-desktop">
      <Image
        src={imagenSrc}
        alt="Dona con personajes"
        class="w-full h-auto object-contain"
      />
    </div>
  </div>

  <div class="w-full lg:w-1/2 flex flex-col items-start lg:items-center justify-center px-6 lg:pr-24 pt-12 lg:pt-0 text-left lg:text-center z-10">
    <p id="change-text" class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4"></p>
    
    <div id="info-table" class="mt-8 hidden opacity-0 lg:block" style="display: none;">
      <table class="min-w-full rounded-xl border-2 border-gray-200 bg-white/90  backdrop-blur-sm">
        <caption class="text-2xl text-black mb-2">Aqui esta la tabla:(</caption>
        <thead class="bg-linear-to-r from-sky-400 via-yellow-200 to-red-600">
          <tr>
            <th class="px-6 py-3 text-left text-black">Nivel</th>
            <th class="px-6 py-3 text-left text-black">Institución</th>
            <th class="px-6 py-3 text-left text-black">Años</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <tr class="transition-colors hover:bg-blue-50">
            <td class="px-6 py-4 font-medium">Universidad</td>
            <td class="px-6 py-4">Universidad del Cauca</td>
            <td class="px-6 py-4">2023-2026</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="lg:hidden w-full flex justify-center mt-auto pb-6 overflow-hidden">
    <div class="w-64 aspect-square transform translate-y-[-0%]" id="dona-mobile">
      <Image
        src={imagenSrc}
        alt="Dona con personajes"
        class="w-full h-auto object-contain"
      />
    </div>
  </div>
</section>

<style is:global>
  #info-table {
    transition: all 0.5s ease;
  }
.pin-spacer,
#RotationSection {
  box-shadow: none !important;
  filter: none !important;
}
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const donaDesktop = document.querySelector('#dona-desktop img');
    const donaMobile = document.querySelector('#dona-mobile img');
    const textoRotate = ["Nivel: Universidad", "Institución: Universidad del cauca", "Años: 2023-2026"];
    const changeText = document.getElementById('change-text');
    const infoTable = document.getElementById('info-table');
    const colorsRotate = ['text-blue-600', 'text-yellow-600', 'text-red-600'];
    const section = document.getElementById('RotationSection');

    const donas = [];
    if (donaDesktop) donas.push(donaDesktop);
    if (donaMobile) donas.push(donaMobile);

    const coloresRGB = [
      { r: 255, g: 255, b: 255 }, 
      { r: 13, g: 186, b: 248 },   
      { r: 217, g: 213, b: 47 },    
      { r: 180, g: 43, b: 49 }      
    ];

    gsap.set(donas, {
      rotate: 270,
      transformOrigin: "50% 61.94%"
    });

    if(!changeText || !infoTable || !section) return;
    changeText.innerText = '';
    changeText.style.opacity = '0';
    changeText.style.transform = 'translateY(20px)';
    changeText.style.display = 'block';
    infoTable.style.display = 'none';
    infoTable.style.opacity = '0';

    section.style.background = `linear-gradient(135deg, rgb(255,255,255), rgb(240,240,255))`;
    section.style.boxShadow = 'none';

    let textoActual = -1;
    let tablaVisible = false;

    const tl = gsap.timeline({
      scrollTrigger: {
        id:"roundedsection",
        trigger: "#RotationSection",
        start: "top top",          
        end: "+=300%",
        pin: true,            
        scrub: 1.5,
        anticipatePin: 1,
        onLeaveBack: () => {
          if (tablaVisible) {
            tablaVisible = false;
            gsap.to(infoTable, {
              opacity: 0,
              scale: 0.8,
              duration: 0.3,
              onComplete: () => {
                infoTable.style.display = 'none';
              }
            });
          }
        }
      }
    });

    tl.to(donas, {
      rotate: 270 + 360,
      duration: 1,
      ease: "none",
      onUpdate: function() {
        const progreso = this.progress();
        const gradosAvanzados = progreso * 360;
        
        let colorInicio, colorFin, tLocal;
        if (progreso < 0.33) {
          colorInicio = coloresRGB[0];
          colorFin = coloresRGB[1];
          tLocal = progreso / 0.33;
        } else if (progreso < 0.66) {
          colorInicio = coloresRGB[1];
          colorFin = coloresRGB[2];
          tLocal = (progreso - 0.33) / 0.33;
        } else {
          colorInicio = coloresRGB[2];
          colorFin = coloresRGB[3];
          tLocal = (progreso - 0.66) / 0.34;
        }
        
        const r = Math.round(colorInicio.r + (colorFin.r - colorInicio.r) * tLocal);
        const g = Math.round(colorInicio.g + (colorFin.g - colorInicio.g) * tLocal);
        const b = Math.round(colorInicio.b + (colorFin.b - colorInicio.b) * tLocal);
        
        section.style.background = `linear-gradient(135deg, rgb(${r},${g},${b}), rgb(${Math.min(r+40,255)},${Math.min(g+30,255)},${Math.min(b+30,255)}))`;
        
        if (gradosAvanzados < 330) {
          
          if (tablaVisible) {
            tablaVisible = false;
            gsap.to(infoTable, {
              opacity: 0,
              scale: 0.8,
              duration: 0.3,
              onComplete: () => {
                infoTable.style.display = 'none';
                changeText.style.display = 'block';
              }
            });
          }
          
          if (gradosAvanzados < 90) {
            if (textoActual !== -1) {
              textoActual = -1;
              gsap.to(changeText, {
                opacity: 0,
                y: 20,
                duration: 0.3,
                onComplete: () => {
                  changeText.innerText = ''; 
                }
              });
            }
          } 
          else {
            const progresoTexto = (gradosAvanzados - 90) / 240;
            let nuevoIndice;
            
            if (progresoTexto < 0.33) nuevoIndice = 0;
            else if (progresoTexto < 0.66) nuevoIndice = 1;
            else nuevoIndice = 2;
            
            if (nuevoIndice !== textoActual && nuevoIndice !== undefined) {
              textoActual = nuevoIndice;
              
              gsap.to(changeText, {
                opacity: 0,
                y: -20,
                duration: 0.3,
                onComplete: () => {
                  changeText.innerText = textoRotate[textoActual];
                  changeText.className = changeText.className.replace(/text-\w+-\d+/g, '');
                  changeText.classList.add(colorsRotate[textoActual]);
                  
                  gsap.fromTo(changeText, 
                    { opacity: 0, y: 20 },
                    { opacity: 1, y: 0, duration: 0.5, ease: "back.out(1.2)" }
                  );
                }
              });
            }
          }
        } 
        else {
          if (!tablaVisible) {
            tablaVisible = true;
            animateTable();
          }
        }
      }
    });

    function animateTable() {
      gsap.to(changeText, {
        opacity: 0,
        y: -30,
        duration: 0.3,
        onComplete: () => {
          changeText!.style.display = 'none';
          changeText!.innerText = ''; 
          
          infoTable!.style.display = 'block';
          
          gsap.fromTo(infoTable, 
            {
              opacity: 0,
              scale: 0.7,
              rotation: -10,
              y: 50,
              filter: "blur(10px)"
            },
            {
              opacity: 1,
              scale: 1,
              rotation: 0,
              y: 0,
              filter: "blur(0px)",
              duration: 0.8,
              ease: "back.out(1.2)",
            }
          );
        }
      });
    }

    return () => {
      if (tl.scrollTrigger) {
        tl.scrollTrigger.kill();
      }
      tl.kill();
    };
  });
</script>